#!/usr/bin/env bash
# claude-docker - Run Claude Code inside a sandboxed Docker container.
#
# This script builds the sandbox image on first use, then runs
# claude inside a container with the project directory mounted
# read-write and the ~/.claude config directory persisted.

set -euo pipefail

IMAGE_NAME="claude-code-sandbox"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DOCKERFILE_DIR="${SCRIPT_DIR}/../docker/claude-sandbox"

build_image() {
  docker build -t "${IMAGE_NAME}" \
    --build-arg HOST_HOME="${HOME}" "${DOCKERFILE_DIR}" >&2
}

# Rebuild when the image is missing, or was built for a different home. The
# image symlinks the host home to /home/node so the shared ~/.claude (which
# stores absolute paths, e.g. plugin install locations) resolves. A cached
# image built for the wrong home lacks that symlink, so config and credentials
# never persist and Claude re-onboards every launch.
IMAGE_HOME="$(docker image inspect \
  -f '{{index .Config.Labels "host_home"}}' "${IMAGE_NAME}" 2>/dev/null || true)"
if [ "${IMAGE_HOME}" != "${HOME}" ]; then
  echo "Building Claude sandbox image..." >&2
  build_image
fi

PROJECT_DIR="$(pwd)"
CONTAINER_HOME="/home/node"

# Container name: claude-{project}-{instance}
PROJECT_SLUG="$(basename "${PROJECT_DIR}")"
if [ -n "${CLAUDE_BUFFER_NAME:-}" ]; then
  INSTANCE="${CLAUDE_BUFFER_NAME##*:}"
  INSTANCE="${INSTANCE%\*}"
  CONTAINER_NAME="claude-${PROJECT_SLUG}-${INSTANCE}"
else
  CONTAINER_NAME="claude-${PROJECT_SLUG}"
fi
CONTAINER_NAME="$(echo "${CONTAINER_NAME}" | \
  tr -cs 'a-zA-Z0-9_.-' '-' | sed 's/^[^a-zA-Z0-9]*//;s/-$//')"

CLAUDE_DIR="${HOME}/.claude"
CLAUDE_STATE_DIR="${HOME}/.local/state/claude"
mkdir -p "${CLAUDE_DIR}" "${CLAUDE_STATE_DIR}"

# Claude writes its global config atomically (temp file + rename). The default
# location, a single-file bind mount of ~/.claude.json, can't be renamed over,
# and the container home is read-only, so every config write is lost and Claude
# re-prompts (theme, folder trust) on each launch. Point CLAUDE_CONFIG_DIR at the
# mounted ~/.claude directory instead: there the config is a regular file in a
# writable mount, so atomic writes persist. Seed it from the host's global config
# on first use so onboarding, theme and account carry over.
CONFIG_JSON="${CLAUDE_DIR}/.claude.json"
if [ ! -f "${CONFIG_JSON}" ] && [ -f "${HOME}/.claude.json" ]; then
  cp "${HOME}/.claude.json" "${CONFIG_JSON}"
fi

DOCKER_ARGS=(
  --rm
  -it
  # Run under the host home path (symlinked to /home/node in the image) so
  # absolute paths in the shared ~/.claude config resolve consistently.
  -e HOME="${HOME}"
  -e TERM=xterm-256color
  -e INSIDE_EMACS=
  -e CLAUDE_CONFIG_DIR="${CONTAINER_HOME}/.claude"
  -v "${PROJECT_DIR}:${PROJECT_DIR}:z"
  -v "${CLAUDE_DIR}:${CONTAINER_HOME}/.claude:z"
  # Note: ~/.local/share/claude is NOT mounted. It holds the versioned claude
  # binary the launcher symlinks to; mounting the host's copy shadows the image's
  # baked-in version, dangling the symlink (exit 127). The image owns the version
  # (auto-updater is off, update = rebuild), so keep it self-contained.
  -v "${CLAUDE_STATE_DIR}:${CONTAINER_HOME}/.local/state/claude:z"
  -w "${PROJECT_DIR}"
  --user "$(id -u):$(id -g)"
  --cap-drop=ALL
  --security-opt=no-new-privileges
  --read-only
  --tmpfs /tmp
  --tmpfs "${CONTAINER_HOME}/.cache"
  --tmpfs "${CONTAINER_HOME}/.config"
  --tmpfs "${CONTAINER_HOME}/.npm"
  --pids-limit=512
  --name "${CONTAINER_NAME}"
)

# Docker socket proxy - gives read-only visibility into
# containers (ps, inspect, logs) without write access.
# POST/EXEC stay off: a write call to the host daemon (which
# runs as root) would let this container spawn a sibling that
# mounts the host filesystem, escaping the sandbox entirely.
DOCKER_SOCK="/var/run/docker.sock"
PROXY_NAME="claude-docker-proxy"
PROXY_NET="claude-docker-proxy-net"

if [ -S "${DOCKER_SOCK}" ]; then
  if ! docker network inspect "${PROXY_NET}" >/dev/null 2>&1; then
    docker network create "${PROXY_NET}" >/dev/null
  fi

  if ! docker container inspect -f '{{.State.Running}}' \
       "${PROXY_NAME}" 2>/dev/null | grep -q true; then
    docker rm -f "${PROXY_NAME}" >/dev/null 2>&1 || true
    docker run -d \
      --name "${PROXY_NAME}" \
      --network "${PROXY_NET}" \
      --restart unless-stopped \
      -v "${DOCKER_SOCK}:/var/run/docker.sock:ro" \
      -e CONTAINERS=1 \
      -e EXEC=0 \
      -e POST=0 \
      -e LOG=1 \
      -e INFO=1 \
      -e IMAGES=0 \
      -e NETWORKS=0 \
      -e VOLUMES=0 \
      -e SERVICES=0 \
      -e TASKS=0 \
      -e BUILD=0 \
      -e COMMIT=0 \
      -e SWARM=0 \
      tecnativa/docker-socket-proxy >/dev/null
  fi

  DOCKER_ARGS+=(
    --network "${PROXY_NET}"
    -e DOCKER_HOST="tcp://${PROXY_NAME}:2375"
  )
fi

# Pass through optional env vars if set
for var in ANTHROPIC_API_KEY CLAUDE_BUFFER_NAME; do
  if [ -n "${!var+x}" ]; then
    DOCKER_ARGS+=(-e "${var}")
  fi
done

# Forward SSH agent if available
MACOS_SSH_SOCK="/run/host-services/ssh-auth.sock"
if [ "$(uname)" = "Darwin" ] && [ -e "${MACOS_SSH_SOCK}" ]; then
  DOCKER_ARGS+=(
    -v "${MACOS_SSH_SOCK}:/tmp/ssh-agent.sock"
    -e SSH_AUTH_SOCK=/tmp/ssh-agent.sock
  )
elif [ -n "${SSH_AUTH_SOCK:-}" ]; then
  DOCKER_ARGS+=(
    -v "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:z"
    -e SSH_AUTH_SOCK=/tmp/ssh-agent.sock
  )
fi

# Shadow .env files so secrets are never visible inside the container
while IFS= read -r -d '' envfile; do
  DOCKER_ARGS+=(-v "/dev/null:${envfile}:ro")
done < <(find "${PROJECT_DIR}" -maxdepth 5 \
  \( -name '.env' -o -name '.env.*' -o -name '.env.local' \) \
  -print0 2>/dev/null)

# Forward git config (read-only)
if [ -f "${HOME}/.gitconfig" ]; then
  DOCKER_ARGS+=(
    -v "${HOME}/.gitconfig:${CONTAINER_HOME}/.gitconfig:ro,z"
  )
fi
XDG_GIT="${XDG_CONFIG_HOME:-${HOME}/.config}/git"
if [ -d "${XDG_GIT}" ]; then
  DOCKER_ARGS+=(
    -v "${XDG_GIT}:${CONTAINER_HOME}/.config/git:ro,z"
  )
fi

exec docker run "${DOCKER_ARGS[@]}" "${IMAGE_NAME}" "$@"
